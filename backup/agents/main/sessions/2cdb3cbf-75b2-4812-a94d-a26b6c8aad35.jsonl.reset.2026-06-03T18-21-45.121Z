-euo pipefail\n# Backup configs\ncp /root/.openclaw/openclaw.json /root/.openclaw/openclaw.json.bak-openclaw-domain-$(date +%Y%m%d%H%M%S)\ncp /etc/easypanel/traefik/config/main.yaml /etc/easypanel/traefik/config/main.yaml.bak-openclaw-domain-$(date +%Y%m%d%H%M%S)\n\n# Allow browser origin for the custom domain\npython3 - <<'PY'\nimport json\nfrom pathlib import Path\np=Path('/root/.openclaw/openclaw.json')\ndata=json.loads(p.read_text())\ngw=data.setdefault('gateway', {})\nui=gw.setdefault('controlUi', {})\norigins=set(ui.get('allowedOrigins') or [])\norigins.update(['https://sharkdalovable.digital','https://www.sharkdalovable.digital'])\nui['allowedOrigins']=sorted(origins)\np.write_text(json.dumps(data, indent=2, ensure_ascii=False)+\"\\n\")\nPY\n\n# Create internal TCP proxy from Docker gateway bridge to OpenClaw loopback\ncat > /etc/systemd/system/openclaw-docker-proxy.socket <<'EOF'\n[Unit]\nDescription=OpenClaw Gateway proxy socket for Docker Traefik\n\n[Socket]\nListenStream=172.16.1.1:18790\nNoDelay=true\n\n[Install]\nWantedBy=sockets.target\nEOF\n\ncat > /etc/systemd/system/openclaw-docker-proxy@.service <<'EOF'\n[Unit]\nDescription=OpenClaw Gateway proxy connection to loopback\n\n[Service]\nExecStart=/lib/systemd/systemd-socket-proxyd 127.0.0.1:18789\nPrivateTmp=true\nNoNewPrivileges=true\nEOF\n\nsystemctl daemon-reload\nsystemctl enable --now openclaw-docker-proxy.socket\n\n# Add Traefik routers/services for OpenClaw domain\npython3 - <<'PY'\nimport json\nfrom pathlib import Path\np=Path('/etc/easypanel/traefik/config/main.yaml')\ndata=json.loads(p.read_text())\nhttp=data.setdefault('http', {})\nrouters=http.setdefault('routers', {})\nservices=http.setdefault('services', {})\nrouters['http-openclaw-sharkdomain']={\n  'service':'openclaw-gateway',\n  'rule':'Host(`sharkdalovable.digital`) || Host(`www.sharkdalovable.digital`)',\n  'middlewares':['redirect-to-https','bad-gateway-error-page'],\n  'entryPoints':['http'],\n  'priority':10\n}\nrouters['https-openclaw-sharkdomain']={\n  'service':'openclaw-gateway',\n  'rule':'Host(`sharkdalovable.digital`) || Host(`www.sharkdalovable.digital`)',\n  'middlewares':['bad-gateway-error-page'],\n  'tls':{'certResolver':'letsencrypt','domains':[{'main':'sharkdalovable.digital','sans':['www.sharkdalovable.digital']}]},\n  'entryPoints':['https'],\n  'priority':10\n}\nservices['openclaw-gateway']={\n  'loadBalancer':{\n    'servers':[{'url':'http://172.16.1.1:18790/'}],\n    'passHostHeader': True\n  }\n}\np.write_text(json.dumps(data, indent=2)+\"\\n\")\nPY\n\n# Restart gateway so allowedOrigins takes effect, Traefik watches file automatically\nopenclaw gateway restart\nsleep 2\nsystemctl status openclaw-docker-proxy.socket --no-pager -l | sed -n '1,25p'\n","workdir":"/root/.openclaw/workspace","yieldMs":10000,"timeout":60}}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.5","usage":{"input":246,"output":1315,"cacheRead":44032,"cacheWrite":0,"totalTokens":45593,"cost":{"input":0.0012300000000000002,"output":0.03945,"cacheRead":0.022015999999999997,"cacheWrite":0,"total":0.062696}},"stopReason":"toolUse","timestamp":1778720337499,"responseId":"resp_094b6994f4566fc6016a051e53932081949e95fd6a6e57f0a0"}}
