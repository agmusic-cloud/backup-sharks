# OpenClaw sensitive/runtime data - never commit raw
credentials/
telegram/
identity/
delivery-queue/
locks/
tui/
tasks/
logs/
exec-approvals.json
update-check.json

# Raw configs contain auth tokens / bot tokens. Keep sanitized copies in backup/ only.
openclaw.json
openclaw.json.*
*.bak
*.last-good

# Heavy/generated artifacts
npm/
media/
canvas/
completions/
plugins/
plugin-skills/

# Original runtime/workspaces are snapshotted into backup/
agents/
workspace/
workspace-sharkzap/
memory/

# Memory recall cache
**/memory/.dreams/

# OS/editor noise
.DS_Store
*.swp
